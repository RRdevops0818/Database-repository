--1. Create a database (optional, skip if you already have one)
CREATE DATABASE IF NOT EXISTS company_db;

-- Switch to the database
USE company_db;

-- 2. Create a table for employees
CREATE TABLE employees (
    id INT PRIMARY KEY AUTO_INCREMENT,  -- Unique employee ID
    name VARCHAR(100) NOT NULL,          -- Employee name
    department VARCHAR(50),              -- Department name
    salary DECIMAL(10, 2) CHECK (salary >= 0), -- Salary must be non-negative
    hire_date DATE DEFAULT CURRENT_DATE  -- Default to today's date
);

-- 3. Insert sample data
INSERT INTO employees (name, department, salary, hire_date) VALUES
('Alice Johnson', 'HR', 50000.00, '2022-05-10'),
('Bob Smith', 'IT', 65000.00, '2021-03-15'),
('Charlie Brown', 'Finance', 70000.00, '2020-11-01');


-- 4. Query all employees
SELECT * FROM employees;

-- 5. Query employees with salary above 60,000
SELECT name, department, salary
FROM employees
WHERE salary > 60000
ORDER BY salary DESC;

-- 6. Update salary for a specific employee
UPDATE employees
SET salary = salary + 5000
WHERE name = 'Bob Smith';

-- 7. Delete an employee record
DELETE FROM employees
WHERE id = 1;

